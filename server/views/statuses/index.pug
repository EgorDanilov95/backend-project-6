extends ../layouts/application.pug


block header
  = t('views.statuses.header')

block content
  .mt-4 
    table.table.table-striped
      thead
        tr
          th= t('views.statuses.id')
          th= t('views.statuses.name')
          th= t('views.statuses.createdAt')
          th= ' '
          
      tbody
        each status in statuses
          tr
            td= status.id
            td= status.name
            td= formatDate(status.created_at)
            td
              if currentUser
                a.btn.btn-primary.btn-sm.me-2(href=`/users/${user.id}/edit`) Изменить
                +buttonTo(`/users/${user.id}`, 'delete')(class="btn btn-danger btn-sm" value="Удалить")